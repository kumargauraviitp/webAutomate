# WordPress Configuration
WP_URL=Your Wordpress url here
WP_USERNAME=Wordpress Username
# Get this from User -> Profile -> Application Passwords in WP Dashboard
WP_APP_PASSWORD=Wordpress Password

# Telegram Configuration
# Get from @BotFather
TELEGRAM_BOT_TOKEN=Telegram BotFather Token
# Your Telegram Username (e.g. janesmith) - do NOT include the '@' symbol.
# Comma-separated for multiple admins: admin1,admin2
AUTHORIZED_USERNAMES=Telegram usernames
# Admin username(s) for startup notifications (no '@' needed)
# Comma-separated for multiple admins: admin1,admin2
ADMIN_USERNAME=Telegram Usernames
# Telegram username shown to unauthorized users in the denial message (no '@' needed)
CONTACT_USERNAME=your_telegram_username

# Security & Data Storage
# ID of a private Telegram Channel where the bot is Admin (-100xxxxxx) to store logs silently.
LOG_CHANNEL_ID=-1000000000000

# Usernames that MUST be admins in your database channel for /verifychannel to work
DATABASE_ADMIN_USERNAMES=your_telegram_username

# Render keep-alive — DO NOT set this in Render dashboard, Render injects it automatically.
# Only set this locally if you want to test the pinger (use your actual Render URL).
# RENDER_EXTERNAL_URL=https://your-bot.onrender.com